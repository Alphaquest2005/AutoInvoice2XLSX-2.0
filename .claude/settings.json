{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 scripts/hooks/claude_code_adapter.py"
          },
          {
            "type": "command",
            "command": "python3 scripts/hooks/check_magic_ok_registry.py"
          },
          {
            "type": "command",
            "command": "python3 scripts/hooks/check_config_meta.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/auto-commit.sh"
          }
        ]
      }
    ]
  }
}
