{
  "name": "autoinvoice2xlsx",
  "version": "2.0.0",
  "type": "commonjs",
  "description": "CARICOM Invoice Processing Pipeline - Electron Desktop Application",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && electron-builder --win",
    "test:e2e": "npx playwright test --config=playwright.config.ts",
    "test:e2e:ui": "npx playwright test --config=playwright.config.ts --ui"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@rollup/rollup-linux-x64-gnu": "^4.57.1",
    "better-sqlite3": "^11.7.0",
    "chokidar": "^4.0.3",
    "imap": "^0.8.19",
    "js-yaml": "^4.1.0",
    "lucide-react": "^0.469.0",
    "mailparser": "^3.9.3",
    "nodemailer": "^8.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.3",
    "react-resizable-panels": "^2.1.7",
    "react-syntax-highlighter": "^15.6.1",
    "react-window": "^1.8.11",
    "remark-gfm": "^4.0.0",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/imap": "^0.8.43",
    "@types/js-yaml": "^4.0.9",
    "@types/mailparser": "^3.4.6",
    "@types/nodemailer": "^7.0.9",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/react-window": "^1.8.8",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "playwright-core": "^1.58.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6",
    "wait-on": "^8.0.2"
  }
